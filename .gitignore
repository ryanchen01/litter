# macOS
.DS_Store

# Build system stamps
.build-stamps/

# Xcode user/workspace state
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/

# Build outputs
.build/
build/
DerivedData/
apps/android/.gradle/
apps/ios/Frameworks/
apps/ios/GeneratedRust/
apps/ios/Litter.xcodeproj/Litter.xcodeproj/
apps/ios/fastlane/report.xml
apps/ios/fastlane/screenshots/

# SwiftPM
Packages/

# Rust
**/target/

# Generated code (codegen + UniFFI — regenerate with build-rust.sh)
*.generated.rs
*.generated.swift
shared/rust-bridge/generated/

# Android JNI outputs (generated from Rust bridge)
apps/android/core/bridge/src/main/jniLibs/*/*.so

# Logs and temp
*.log
*.tmp
tmp/

# Local screenshots
Simulator Screenshot*.png

# IDE and Android Environment Defaults
.idea/
*.iml
local.properties
apps/android/.idea/
apps/android/build/
apps/android/app/build/
apps/android/core/*/build/
apps/android/feature/*/build/

# Local schema snapshots
docs/codex-schema/
apps/android/app/src/main/assets/bundled_env/
apps/android/kls_database.db
node_modules/

# Factory/Droid
.factory/
.claude/
shared/third_party/codex/
